# Public site URL
NEXT_PUBLIC_SITE_URL=https://pllana.io

# Google PageSpeed Insights API v5 (server-side only)
PAGESPEED_API_KEY=

# At least 32 random characters; used to sign analysis and Double-Opt-in tokens
WEBSITE_CHECK_TOKEN_SECRET=

# Existing SMTP integration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
CONTACT_TO_EMAIL=info@pllana.io
WEBSITE_CHECK_TO_EMAIL=info@pllana.io

# Optional CRM / lead and confirmed-marketing webhooks
WEBSITE_CHECK_LEAD_WEBHOOK_URL=
WEBSITE_CHECK_MARKETING_WEBHOOK_URL=

# Optional distributed rate limiting (Upstash/Vercel KV-compatible REST API)
WEBSITE_CHECK_KV_REST_URL=
WEBSITE_CHECK_KV_REST_TOKEN=

# Optional Cloudflare Turnstile; configure both values together
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
